# Agent Inc. — copy to .env and fill in. Never commit .env (it is gitignored).

# The linchpin: routes the agent through the HUD gateway for Claude / Gemini /
# Qwen AND powers the LLM-judge (quality, 30% of reward). Redeem YC-RL-HACKATHON
# at hud.ai/project/api-keys.  Or run: hud set HUD_API_KEY=...
HUD_API_KEY=

# Live research tools (optional — tools fall back to clearly-labelled mocks without them)
EXA_API_KEY=
SIXTYFOUR_API_KEY=

# RL training (Phase 3): Fireworks RFT/SFT on qwen3-4b
FIREWORKS_API_KEY=
